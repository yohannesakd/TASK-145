<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorSurface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_xl">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/dashboard_compliance_title"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Open Cases (full width) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_open_cases"
            android:layout_width="0dp"
            android:layout_height="@dimen/dashboard_card_min_height"
            android:layout_marginTop="@dimen/spacing_lg"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="@dimen/corner_radius_md"
            app:cardElevation="@dimen/card_elevation"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_title">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_open_cases_count"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceHeadlineMedium"
                    android:textColor="@color/colorError" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/card_open_cases"
                    android:textAppearance="?attr/textAppearanceTitleSmall" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_tap_to_view"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Pending Employers | Reports -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_pending_employers"
            android:layout_width="0dp"
            android:layout_height="@dimen/dashboard_card_min_height"
            android:layout_marginTop="@dimen/spacing_sm"
            android:layout_marginEnd="@dimen/spacing_xs"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="@dimen/corner_radius_md"
            app:cardElevation="@dimen/card_elevation"
            app:layout_constraintEnd_toStartOf="@id/card_reports"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_open_cases">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_pending_employers_count"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceHeadlineMedium"
                    android:textColor="@color/status_pending" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/card_pending_employers"
                    android:textAppearance="?attr/textAppearanceTitleSmall" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_tap_to_view"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_reports"
            android:layout_width="0dp"
            android:layout_height="@dimen/dashboard_card_min_height"
            android:layout_marginTop="@dimen/spacing_sm"
            android:layout_marginStart="@dimen/spacing_xs"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="@dimen/corner_radius_md"
            app:cardElevation="@dimen/card_elevation"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/card_pending_employers"
            app:layout_constraintTop_toBottomOf="@id/card_open_cases">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_reports_count"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceHeadlineMedium"
                    android:textColor="@color/colorPrimary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/card_reports"
                    android:textAppearance="?attr/textAppearanceTitleSmall" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_tap_to_view"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Audit: Tasks | Orders -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_audit_tasks"
            android:layout_width="0dp"
            android:layout_height="@dimen/dashboard_card_min_height"
            android:layout_marginTop="@dimen/spacing_sm"
            android:layout_marginEnd="@dimen/spacing_xs"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="@dimen/corner_radius_md"
            app:cardElevation="@dimen/card_elevation"
            app:layout_constraintEnd_toStartOf="@id/card_audit_orders"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_pending_employers">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Audit Tasks"
                    android:textAppearance="?attr/textAppearanceTitleSmall" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="View all tasks (read-only)"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_audit_orders"
            android:layout_width="0dp"
            android:layout_height="@dimen/dashboard_card_min_height"
            android:layout_marginTop="@dimen/spacing_sm"
            android:layout_marginStart="@dimen/spacing_xs"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="@dimen/corner_radius_md"
            app:cardElevation="@dimen/card_elevation"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/card_audit_tasks"
            app:layout_constraintTop_toBottomOf="@id/card_pending_employers">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Audit Orders"
                    android:textAppearance="?attr/textAppearanceTitleSmall" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="View all orders (read-only)"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
